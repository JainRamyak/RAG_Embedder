# ── Embedder selection ──────────────────────────────────────────
# Options: local | openai | gemini
EMBEDDER_TYPE=local

# ── Local model (used when EMBEDDER_TYPE=local) ─────────────────
# Options: all-MiniLM-L6-v2 | all-mpnet-base-v2 | paraphrase-multilingual-MiniLM-L12-v2
LOCAL_MODEL_NAME=all-MiniLM-L6-v2

# ── OpenAI (used when EMBEDDER_TYPE=openai) ─────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ── Gemini (used when EMBEDDER_TYPE=gemini) ─────────────────────
GEMINI_API_KEY=your-gemini-key-here

# ── Chunking (for future RAG pipeline) ──────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ── Retrieval ───────────────────────────────────────────────────
TOP_K_RETRIEVAL=5

# ── Logging ─────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO